<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.browseros.BrowserOS</id>
  <name>BrowserOS</name>
  <summary>The open-source agentic browser</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-only</project_license>
  <developer id="com.browseros">
    <name>BrowserOS Team</name>
  </developer>
  <url type="homepage">https://www.browseros.com/</url>
  <url type="bugtracker">https://github.com/browseros-ai/BrowserOS/issues</url>
  <url type="vcs-browser">https://github.com/browseros-ai/BrowserOS</url>
  <description>
    <p>This is a community package of BrowserOS, maintained independently. It repackages the official upstream Debian build unmodified and downloads it at install time.</p>
    <p>BrowserOS is a privacy-focused web browser built on Chromium, designed for modern web browsing with AI capabilities.</p>
    <p>Features include:</p>
    <ul>
      <li>Built-in AI agent for agentic web browsing</li>
      <li>Privacy-focused patches from ungoogled-chromium</li>
      <li>Chromium compatibility for extensions and web standards</li>
      <li>Support for local LLMs via Ollama and LM Studio</li>
    </ul>
    <p>Permissions: this package grants the browser network, display, audio, GPU, printing, smart-card, Bluetooth, WebRTC screen-capture and selected desktop integration access. It does not grant broad home-directory access; downloads, desktop files, icons, host policy files and proxy settings are exposed for normal browser and PWA workflows.</p>
  </description>
  <screenshots>
    <screenshot type="default">
      <caption>BrowserOS main window</caption>
      <image type="source">https://www.browseros.com/og-image.png</image>
    </screenshot>
  </screenshots>
  <launchable type="desktop-id">com.browseros.BrowserOS.desktop</launchable>
  <categories>
    <category>Network</category>
    <category>WebBrowser</category>
  </categories>
  <keywords>
    <keyword>browser</keyword>
    <keyword>chromium</keyword>
    <keyword>web</keyword>
    <keyword>ai</keyword>
    <keyword>agent</keyword>
  </keywords>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
  </recommends>
  <content_rating type="oars-1.1" />
  <provides>
    <binary>browseros</binary>
    <mediatype>text/html</mediatype>
    <mediatype>text/xml</mediatype>
    <mediatype>application/xhtml+xml</mediatype>
    <mediatype>application/xml</mediatype>
    <mediatype>x-scheme-handler/http</mediatype>
    <mediatype>x-scheme-handler/https</mediatype>
    <mediatype>x-scheme-handler/ftp</mediatype>
  </provides>
  <releases>
    <release version="0.46.0" date="2026-06-17" />
  </releases>
</component>

