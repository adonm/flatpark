[Desktop Entry]
Type=Application
Name=BrowserOS
GenericName=Web Browser
Comment=Browse the web with a local AI agent
Exec=browseros %U
Icon=com.browseros.BrowserOS
Terminal=false
StartupNotify=true
StartupWMClass=BrowserOS
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;application/xml;x-scheme-handler/http;x-scheme-handler/https;x-scheme-handler/ftp;
Keywords=browser;chromium;web;ai;agent;

